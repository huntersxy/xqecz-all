[Unit]
Description=xqecz-all Server
After=network.target mysql.service redis.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/www/wwwroot/xqecz-all/dist
ExecStart=/www/wwwroot/xqecz-all/dist/server
Restart=always
RestartSec=3

# 环境变量
Environment=HOME=/root
Environment=GOPATH=/root/go
Environment=GOCACHE=/root/.cache/go-build

# 限制
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
