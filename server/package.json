{
  "name": "xqecz-server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "xqecz Node.js + TypeScript + Express backend with MySQL + Redis",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.6.0",
    "ffmpeg-static": "^5.3.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.6.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.14.1",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
